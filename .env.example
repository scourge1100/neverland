# Neverland local defaults.
# Copy this file to .env and replace every CHANGE_ME value before running.

HTTPS_PORT=3443
HTTP_PREVIEW_PORT=3080

URL=https://localhost:3443
PORT=3000
FORCE_HTTPS=true
DEFAULT_LANGUAGE=ko_KR

DATABASE_URL=postgres://outline:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/outline
DATABASE_CONNECTION_POOL_MIN=
DATABASE_CONNECTION_POOL_MAX=
PGSSLMODE=disable
REDIS_URL=redis://redis:6379

SECRET_KEY=CHANGE_ME_64_HEX_CHARS
UTILS_SECRET=CHANGE_ME_64_HEX_CHARS

FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FILE_STORAGE_UPLOAD_MAX_SIZE=26214400

OIDC_CLIENT_ID=neverland-outline
OIDC_CLIENT_SECRET=CHANGE_ME_OIDC_CLIENT_SECRET
OIDC_AUTH_URI=https://localhost:3443/dex/auth
OIDC_TOKEN_URI=http://dex:5556/dex/token
OIDC_USERINFO_URI=http://dex:5556/dex/userinfo
OIDC_USERNAME_CLAIM=email
OIDC_DISPLAY_NAME=GitHub Login
OIDC_SCOPES=openid profile email

# Create a GitHub OAuth App and paste the values here.
# Authorization callback URL: https://localhost:3443/dex/callback
GITHUB_CLIENT_ID=CHANGE_ME_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=CHANGE_ME_GITHUB_CLIENT_SECRET

# Public GitHub activity shown on the portfolio. A token is optional for public data.
GITHUB_USERNAME=scourge1100
GITHUB_TOKEN=

POSTGRES_USER=outline
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
POSTGRES_DB=outline

# Replace with the public share URL generated in Outline.
PUBLIC_PORTFOLIO_URL=/public-not-ready.html

BLOG_BASE_URL=https://localhost:3443
BLOG_CACHE_TTL_SECONDS=60

# Production overrides
SITE_DOMAIN=portfolio.example.com
DEX_ISSUER=https://portfolio.example.com/dex
OIDC_REDIRECT_URI=https://portfolio.example.com/auth/oidc.callback
GITHUB_REDIRECT_URI=https://portfolio.example.com/dex/callback
